# Note: each engine version runs as its own service (e.g. postgres14, mysql57,
# pgvector14) so multiple versions can run side by side for different projects.
# To add a version, copy the service block in compose.yml and bump the name/tag.

# http
HTTP_PORT=80
HTTPS_PORT=443

# postgres
POSTGRES_14_PORT=5432
POSTGRES_ROOT_USER=postgres
POSTGRES_ROOT_PASS=postgres
PGVECTOR_PORT=54322

# qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=qdrant_random_api_key

# mysql
MYSQL_56_PORT=33061
MYSQL_57_PORT=33062
MYSQL_80_PORT=33063
MYSQL_ROOT_USER=root
MYSQL_ROOT_PASS=password

# redis
REDIS_PORT=6379

# minio
MINIO_PORT=9005
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniopass

# mongodb
MONGO_PORT=27017
MONGO_USERNAME=root
MONGO_PASSWORD=password

# rabbitmq
RABBITMQ_NODE_HOST_PORT=5672
RABBITMQ_MANAGEMENT_HTTP_HOST_PORT=15672
RABBITMQ_MANAGEMENT_HTTPS_HOST_PORT=15671
RABBITMQ_WEB_STOMP_HOST_PORT=15674

# kafka (KRaft mode)
KAFKA_PORT=29092
# Base64 cluster id; generate a new one with: kafka-storage random-uuid
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk

# crawl4ai
CRAWL4AI_PORT=11235

# docker
DOCKER_COMPOSE="docker compose"

RESTORE_POSTGRES='postgres14'
RESTORE_MYSQL='mysql57'
RESTORE_DB_NAME='testdb'

# traefik
PILOT_TOKEN=

# mailpit
MAILPIT_PORT=1025
MAILPIT_DASHBOARD_PORT=8025

# jenkins
JENKINS_PORT=8080
JENKINS_ADMIN_USER=admin
JENKINS_ADMIN_PASS=admin
