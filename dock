#!/usr/bin/env bash
#
# dock: Docker helper script for the local services stack.
# Wraps docker compose and adds certificate + db-restore convenience commands.
#
# Unknown commands are passed straight through to docker compose, so anything
# `docker compose <x>` supports, `dock <x>` supports too.

set -euo pipefail

# Resolve the project directory from the script location so `dock` works no
# matter the current working directory (e.g. when symlinked onto $PATH).
PROJECT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
readonly PROJECT_DIR

ENV_FILE="${PROJECT_DIR}/.env"
COMPOSE_FILE="${PROJECT_DIR}/compose.yml"
CERTS_DIR="${PROJECT_DIR}/data/certs"
CERTS_YAML="${PROJECT_DIR}/data/certs.yaml"

# ---------------------------------------------------------------------------
# Colours (only when stdout is a terminal that supports them). Defaults keep
# the variables defined so `set -u` never trips on them.
# ---------------------------------------------------------------------------
BOLD="" RED="" GREEN="" YELLOW="" NC=""
if [ -t 1 ] && command -v tput >/dev/null 2>&1; then
    ncolors="$(tput colors 2>/dev/null || echo 0)"
    if [ -n "$ncolors" ] && [ "$ncolors" -ge 8 ]; then
        BOLD="$(tput bold)"; RED="$(tput setaf 1)"; GREEN="$(tput setaf 2)"
        YELLOW="$(tput setaf 3)"; NC="$(tput sgr0)"
    fi
fi

info()  { echo "${GREEN}$*${NC}"; }
warn()  { echo "${YELLOW}$*${NC}" >&2; }
error() { echo "${BOLD}${RED}$*${NC}" >&2; }

# ---------------------------------------------------------------------------
# Environment + compose wrapper
# ---------------------------------------------------------------------------
load_env() {
    if [ ! -f "$ENV_FILE" ]; then
        error "No .env file found at ${ENV_FILE}."
        exit 1
    fi
    # shellcheck disable=SC1090
    source "$ENV_FILE"
}

# Build the compose command as an array so a multi-word DOCKER_COMPOSE
# (e.g. "docker compose" vs "docker-compose") splits safely, and always
# target this project's files regardless of the caller's CWD.
compose() {
    local bin
    read -ra bin <<< "${DOCKER_COMPOSE:-docker compose}"
    "${bin[@]}" --env-file "$ENV_FILE" -f "$COMPOSE_FILE" "$@"
}

ensure_docker_running() {
    if ! docker info >/dev/null 2>&1; then
        error "Docker is not running."
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Help
# ---------------------------------------------------------------------------
display_help() {
    cat >&2 <<EOF
${BOLD}dock${NC}: Docker Helper Script

${YELLOW}Usage:${NC}
  dock COMMAND [options] [arguments]

  Unknown commands are passed through to docker compose.

${YELLOW}Certificate Commands:${NC}
  ${GREEN}dock certs -n <name> -d <domain> [-d <domain> ...]${NC}  Generate certificates
    eg: dock certs -n my_app -d "my-app.localhost" -d "*.my-app.localhost"
  ${GREEN}dock certs:apply${NC}                                    Apply generated certificates

${YELLOW}docker compose Commands:${NC}
  ${GREEN}dock up [service ...]${NC}    Start all (or specific) services in the background
  ${GREEN}dock down${NC}               Stop the stack
  ${GREEN}dock [command]${NC}          Any other docker compose command (ps, logs, build, ...)

${YELLOW}Shell Commands:${NC}
  ${GREEN}dock ssh <service>${NC}        Open a shell in a service container (root)
  ${GREEN}dock ssh user@<service>${NC}   Open a shell as a specific user

${YELLOW}Database Restore Commands:${NC}
  ${GREEN}dock postgres:restore <dump.sql>${NC}  Restore a Postgres dump (\$RESTORE_POSTGRES)
  ${GREEN}dock mysql:restore <dump.sql>${NC}     Restore a MySQL dump (\$RESTORE_MYSQL)
EOF
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_certs() {
    if ! mkcert -help >/dev/null 2>&1; then
        error "'mkcert' is not installed. Refer: https://github.com/FiloSottile/mkcert"
        exit 1
    fi

    local name="" domain
    local -a domains=()
    local OPTIND opt
    while getopts ":n:d:" opt; do
        case "$opt" in
            n) name="$OPTARG" ;;
            d) domains+=("$OPTARG") ;;
            *) error "Usage: dock certs -n <name> -d <domain> [-d <domain> ...]"; exit 1 ;;
        esac
    done

    if [ -z "$name" ]; then
        error "Certificate name is required."
        warn  "Usage: dock certs -n <name> -d <domain> [-d <domain> ...]"
        exit 1
    fi
    if [ "${#domains[@]}" -eq 0 ]; then
        error "At least one domain is required."
        warn  "Usage: dock certs -n <name> -d <domain> [-d <domain> ...]"
        exit 1
    fi

    local dir="${CERTS_DIR}/${name}"
    mkdir -p "$dir"
    mkcert -cert-file "${dir}/cert.pem" -key-file "${dir}/key.pem" "${domains[@]}"

    info "Certificates generated. Apply them with:"
    info "  dock certs:apply"
}

cmd_certs_apply() {
    local -a certs=()
    local domain_dir domain
    for domain_dir in "$CERTS_DIR"/*/; do
        [ -d "$domain_dir" ] || continue        # skip stray files (e.g. .gitignore)
        domain="$(basename "$domain_dir")"
        [ -f "${domain_dir}/cert.pem" ] && [ -f "${domain_dir}/key.pem" ] || continue
        certs+=("{\"certFile\": \"/etc/certs/${domain}/cert.pem\", \"keyFile\": \"/etc/certs/${domain}/key.pem\"}")
    done

    if [ "${#certs[@]}" -eq 0 ]; then
        error "No certificates found in ${CERTS_DIR}. Generate some with: dock certs ..."
        exit 1
    fi

    local IFS=,
    printf 'tls: { certificates: [%s]}\n' "${certs[*]}" > "$CERTS_YAML"

    info "Certificates applied to ${CERTS_YAML}."
    warn "Restart traefik to pick them up:  dock up traefik"
}

cmd_up() {
    ensure_docker_running
    if [ "$#" -eq 0 ]; then
        read -r -p "Do you really want to start all services? [y/N] " reply
        [[ "$reply" =~ ^[Yy]$ ]] || { info "Aborted."; exit 0; }
    fi
    compose up -d --remove-orphans --build "$@"
}

cmd_down() {
    ensure_docker_running
    compose down "$@"
}

cmd_ssh() {
    ensure_docker_running
    if [ "$#" -eq 0 ]; then
        error "Please specify a service name, e.g. 'dock ssh <service>' or 'dock ssh user@<service>'."
        exit 1
    fi

    local target="$1" user service
    if [[ "$target" == *@* ]]; then
        user="${target%%@*}"
        service="${target#*@}"
    else
        service="$target"
    fi

    local -a exec_args=(exec)
    [ -n "${user:-}" ] && exec_args+=(-u "$user")
    compose "${exec_args[@]}" "$service" sh
}

cmd_postgres_restore() {
    ensure_docker_running
    local file="${1:-}"
    [ -n "$file" ] || { error "Usage: dock postgres:restore <dump.sql>"; exit 1; }
    [ -f "$file" ] || { error "File not found: ${file}"; exit 1; }
    compose exec -T "$RESTORE_POSTGRES" \
        psql -U "$POSTGRES_ROOT_USER" -d "$RESTORE_DB_NAME" -w < "$file"
}

cmd_mysql_restore() {
    ensure_docker_running
    local file="${1:-}"
    [ -n "$file" ] || { error "Usage: dock mysql:restore <dump.sql>"; exit 1; }
    [ -f "$file" ] || { error "File not found: ${file}"; exit 1; }
    compose exec -T "$RESTORE_MYSQL" \
        mysql -u "$MYSQL_ROOT_USER" "$RESTORE_DB_NAME" < "$file"
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
main() {
    local cmd="${1:-}"

    case "$cmd" in
        ""|help|-h|-help|--help)
            display_help
            [ -z "$cmd" ] && exit 1 || exit 0
            ;;
    esac

    load_env
    shift   # drop the command; "$@" now holds its arguments

    case "$cmd" in
        certs)            cmd_certs "$@" ;;
        certs:apply)      cmd_certs_apply "$@" ;;
        up)               cmd_up "$@" ;;
        down)             cmd_down "$@" ;;
        ssh)              cmd_ssh "$@" ;;
        postgres:restore) cmd_postgres_restore "$@" ;;
        mysql:restore)    cmd_mysql_restore "$@" ;;
        *)
            ensure_docker_running
            compose "$cmd" "$@" ;;
    esac
}

main "$@"
